                      00001 ; =============================================================================
                      00002 ; SAPER (Minesweeper) dla PIC16F877A + ILI9341 (SPI)
                      00003 ; =============================================================================
                      00004 ; MAPA REJESTRÓW:
                      00005 ;   0x20-0x2C : Warstwa flag    (10x10 = 100 bitów -> 13 bajtów)
                      00006 ;   0x2D-0x39 : Warstwa min     (10x10 = 100 bitów -> 13 bajtów)
                      00007 ;   0x3A-0x46 : Warstwa odkrytych (10x10 = 100 bitów -> 13 bajtów)
                      00008 ;
                      00009 ;   0x50 : Aktualny X kursora (bieżące pole przy rysowaniu)
                      00010 ;   0x51 : Aktualny Y kursora
                      00011 ;   0x54 : Docelowy X (po wciśnięciu przycisku)
                      00012 ;   0x55 : Docelowy Y
                      00013 ;   0x56 : Tymczasowy indeks liniowy
                      00014 ;   0x57 : Tymczasowy (przesunięcie bajtowe / licznik pętli)
                      00015 ;   0x58 : Wynikowa maska bitu
                      00016 ;   0x59 : Adres bazowy warstwy (0x20/0x2D/0x3A)
                      00017 ;   0x60-0x63 : x0, x1, y0, y1 okna LCD
                      00018 ;   0x64-0x65 : Kolor (RGB565, High/Low)
                      00019 ;   0x66-0x67 : Liczniki pętli rysowania kafelka
                      00020 ;   0x70-0x71 : Liczniki opóźnienia
                      00021 ;   0x72-0x74 : Liczniki wypełniania ekranu
                      00022 ;   0x75 : Tymczasowy przy obliczaniu współrzędnych LCD
                      00023 ;   0x76 : Tymczasowy (kopia W)
                      00024 ;   0x78-0x79 : Kopia X/Y przy CHECK_MINE_AT
                      00025 ;   0x7A-0x7B : Współrzędne sąsiada przy licz sąsiadów
                      00026 ;   0x7C : Wynik COUNT_MINES (liczba sąsiadów-min)
                      00027 ;   0x7D : Delta Y sąsiada (-1,0,+1 jako 0xFF,0x00,0x01)
                      00028 ;   0x7E : Delta X sąsiada
                      00029 ;   0x7F : Tymczasowy wynik CHECK_MINE_AT
                      00030 ;
                      00031 ; STOS FLOOD-FILL (0x80-0x9E, 16 pozycji X/Y)
                      00032 ;   0x80-0x8F : Bufor X stosu (16 wpisów)
                      00033 ;   0x90-0x9F : Bufor Y stosu (16 wpisów)
                      00034 ;   0xA0 : Wskaźnik wierzchołka stosu (0-16)
                      00035 ;
                      00036 ; KONTROLA GRY
                      00037 ;   0xA1 : Stan gry (0=trwa, 1=wygrana, 2=przegrana)
                      00038 ;   0xA2 : Licznik odkrytych pól
                      00039 ;   0xA3 : Łączna liczba min
                      00040 ; =============================================================================
                      00041 
                      00042 #include <p16f877a.inc>
