                      00001 ; =============================================================================
                      00002 ; SAPER (Minesweeper) dla PIC16F877A + ILI9341 (SPI)
                      00003 ; WERSJA: 5x5, 7 min, poprawiony flood-fill (BFS na stosie software),
                      00004 ;         poprawiony kolor dla 2 sąsiadów (niebieski 0x001F)
                      00005 ; =============================================================================
                      00006 ; MAPA REJESTRÓW:
                      00007 ;   0x20-0x23 : Warstwa flag    (5x5 = 25 bitów -> 4 bajty)
                      00008 ;   0x24-0x27 : Warstwa min     (5x5 = 25 bitów -> 4 bajty)
                      00009 ;   0x28-0x2B : Warstwa odkrytych (5x5 = 25 bitów -> 4 bajty)
                      00010 ;
                      00011 ;   0x50 : Aktualny X kursora (bieżące pole przy rysowaniu)
                      00012 ;   0x51 : Aktualny Y kursora
                      00013 ;   0x54 : Docelowy X (po wciśnięciu przycisku)
                      00014 ;   0x55 : Docelowy Y
                      00015 ;   0x56 : Tymczasowy indeks liniowy
                      00016 ;   0x57 : Tymczasowy (przesunięcie bajtowe / licznik pętli)
                      00017 ;   0x58 : Wynikowa maska bitu
                      00018 ;   0x59 : Adres bazowy warstwy (0x20/0x24/0x28)
                      00019 ;   0x60-0x63 : x0, x1, y0, y1 okna LCD
                      00020 ;   0x64-0x65 : Kolor (RGB565, High/Low)
                      00021 ;   0x66-0x67 : Liczniki pętli rysowania kafelka
                      00022 ;   0x70-0x71 : Liczniki opóźnienia
                      00023 ;   0x72-0x74 : Liczniki wypełniania ekranu
                      00024 ;   0x75 : Tymczasowy przy obliczaniu współrzędnych LCD
                      00025 ;   0x76 : Tymczasowy (kopia W)
                      00026 ;   0x78-0x79 : Kopia X/Y przy CHECK_MINE_AT
                      00027 ;   0x7A-0x7B : Współrzędne sąsiada przy licz sąsiadów
                      00028 ;   0x7C : Wynik COUNT_MINES (liczba sąsiadów-min)
                      00029 ;   0x7D : Delta Y sąsiada (-1,0,+1 jako 0xFF,0x00,0x01)
                      00030 ;   0x7E : Delta X sąsiada
                      00031 ;   0x7F : Tymczasowy wynik CHECK_MINE_AT
                      00032 ;
                      00033 ; STOS BFS FLOOD-FILL (software stack, 16 pozycji)
                      00034 ;   0x80-0x8F : Bufor X stosu (16 wpisów)
                      00035 ;   0x90-0x9F : Bufor Y stosu (16 wpisów)
                      00036 ;   0xA0 : Wskaźnik wierzchołka stosu (0-16)
                      00037 ;
                      00038 ; KONTROLA GRY
                      00039 ;   0xA1 : Stan gry (0=trwa, 1=wygrana, 2=przegrana)
                      00040 ;   0xA2 : Licznik odkrytych pól
                      00041 ;   0xA3 : Łączna liczba min
                      00042 ;
                      00043 ; ROZMIAR KAFELKA / UKŁAD EKRANU (5x5):
                      00044 ;   Stride = 24px, rozmiar kafelka = 22x22px
                      00045 ;   x0 = X*24 + 60,  x1 = x0+21
                      00046 ;   y0 = Y*24 + 80,  y1 = y0+21
                      00047 ;   Legenda: y=260..273
                      00048 ; =============================================================================
                      00049 
                      00050 #include <p16f877a.inc>
                      00001         LIST
                      00002 
                      00003 ;==========================================================================
