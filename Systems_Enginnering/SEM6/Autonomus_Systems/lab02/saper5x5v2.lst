                      00001 ; SAPER 5x5 dla PIC16F877A + ILI9341 SPI
                      00002 ;
                      00003 ; Rejestry:
                      00004 ;   0x20-0x23 : flagi (25 bitow, 4 bajty)
                      00005 ;   0x24-0x27 : miny
                      00006 ;   0x28-0x2B : odkryte
                      00007 ;   0x50/0x51 : X/Y biezacej pozycji (kursor lub rysowanie)
                      00008 ;   0x54/0x55 : X/Y nowej pozycji kursora
                      00009 ;   0x56/0x57 : indeks liniowy / licznik petli
                      00010 ;   0x58      : maska bitu
                      00011 ;   0x59      : adres bazowy warstwy
                      00012 ;   0x60-0x63 : x0,x1,y0,y1 okna LCD
                      00013 ;   0x64/0x65 : kolor RGB565 (H/L)
                      00014 ;   0x66/0x67 : liczniki petli rysowania
                      00015 ;   0x70/0x71 : liczniki opoznienia
                      00016 ;   0x72-0x74 : liczniki fill ekranu
                      00017 ;   0x75/0x76 : tymczasowe
                      00018 ;   0x78/0x79 : zachowanie X/Y w CHECK_MINE_AT
                      00019 ;   0x7A/0x7B : wspolrzedne sasiada
                      00020 ;   0x7C      : wynik COUNT_MINES
                      00021 ;   0x7D/0x7E : DY/DX w COUNT_MINES
                      00022 ;   0x7F      : wynik CHECK_MINE_AT
                      00023 ;   0x41      : stan gry (0=trwa, 1=wygrana, 2=przegrana)
                      00024 ;   0x42      : licznik odkrytych
                      00025 ;   0x43      : liczba min
                      00026 ;   0x44      : licznik petli sadzenia min
                      00027 ;   0x45      : losowy indeks kandydata
                      00028 ;
                      00029 ; Legenda kolorow odkrytych pol:
                      00030 ;   0 sas. = czarny  (0x0000)
                      00031 ;   1 sas. = zielony (0x07E0)
                      00032 ;   2 sas. = niebieski (0x001F)
                      00033 ;   3 sas. = pomaranczowy (0xFC00)
                      00034 ;   4 sas. = czerwony (0xF800)
                      00035 ;   5 sas. = rozowy (0xF81F)
                      00036 ;   6 sas. = cyan (0x07FF)
                      00037 ;   7 sas. = fioletowy (0x781F)
                      00038 ;   8 sas. = brazowy (0x8400)
                      00039 ;   flaga = zolty (0xFFE0)
                      00040 ;   kursor = bialy (0xFFFF)
                      00041 ;   zaslepka = szary (0x8410)
                      00042 ;
                      00043 ; Przyciski: RB0=UP RB1=LEFT RB2=DOWN RB3=RIGHT RB4=FLAGA RB6=ODKRYJ RB7=RESTART
                      00044 ;
                      00045 ; Kafelek 22x22px, stride 24:
                      00046 ;   x0 = X*24+60, y0 = Y*24+80
                      00047 
                      00048 #include <p16f877a.inc>
                      00001         LIST
                      00002 
                      00003 ;==========================================================================
                      00004 ; Build date : Aug 07 2014
                      00005 ;  MPASM PIC16F877A processor include
