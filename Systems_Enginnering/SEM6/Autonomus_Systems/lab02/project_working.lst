                      00001 ; =============================================================================
                      00002 ; SAPER (Minesweeper) dla PIC16F877A + ILI9341 (SPI)
                      00003 ; =============================================================================
                      00004 ;
                      00005 ; PRZYCISKI (active-low, PORTB z wbudowanymi pull-upami):
                      00006 ;   RB0 = UP       (kursor w górę)
                      00007 ;   RB1 = DOWN     (kursor w dół)
                      00008 ;   RB2 = LEFT     (kursor w lewo)
                      00009 ;   RB3 = RIGHT    (kursor w prawo)
                      00010 ;   RB4 = REVEAL   (odkryj pole)
                      00011 ;   RB5 = FLAG     (postaw/zdejmij flagę)
                      00012 ;   RB6 = RESTART  (nowa gra)
                      00013 ;
                      00014 ; MAPA PAMIĘCI RAM:
                      00015 ;   0x20-0x2C : warstwa MIN      (10*10 = 100 bitów -> 13 bajtów)
                      00016 ;   0x2D-0x39 : warstwa FLAGI    (10*10 bitów)
                      00017 ;   0x3A-0x46 : warstwa ODKRYTE  (10*10 bitów)
                      00018 ;
                      00019 ;   0x50 : kursor X (0-9)
                      00020 ;   0x51 : kursor Y (0-9)
                      00021 ;
                      00022 ;   0x60 : roboczy X pola
                      00023 ;   0x61 : roboczy Y pola
                      00024 ;   0x62 : adres bazowy warstwy
                      00025 ;   0x63 : wynik GET_BIT (0 lub 1)
                      00026 ;   0x64 : maska bitu (1 bajt)
                      00027 ;   0x65 : tmp ogolny
                      00028 ;   0x66 : tmp ogolny
                      00029 ;   0x67 : tmp ogolny
                      00030 ;
                      00031 ;   0x68 : kolor H (RGB565 high byte)
                      00032 ;   0x69 : kolor L (RGB565 low byte)
                      00033 ;
                      00034 ;   0x70 : wynik COUNT_NEIGHBORS (0-8, 0xFF = błąd/skip)
                      00035 ;   0x71 : DY pętli sąsiadów
                      00036 ;   0x72 : DX pętli sąsiadów
                      00037 ;   0x73 : roboczy sX
                      00038 ;   0x74 : roboczy sY
                      00039 ;   0x75 : roboczy (różne)
                      00040 ;   0x76 : roboczy (różne)
                      00041 ;
                      00042 ;   0x78 : licznik delay outer
                      00043 ;   0x79 : licznik delay inner
                      00044 ;   0x7A-0x7C : liczniki wypełnienia ekranu
                      00045 ;
                      00046 ;   0x7D : LFSR high
                      00047 ;   0x7E : LFSR low
                      00048 ;   0x7F : licznik pętli plant mines
                      00049 ;
                      00050 ;   STOS BFS (flood-fill):
                      00051 ;   0x80-0x8F : X wpisów stosu (16 miejsc)
                      00052 ;   0x90-0x9F : Y wpisów stosu (16 miejsc)
                      00053 ;   0xA0      : wierzchołek stosu (0-16)
