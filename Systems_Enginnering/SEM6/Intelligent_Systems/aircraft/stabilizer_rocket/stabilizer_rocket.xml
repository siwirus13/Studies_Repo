<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="http://jsbsim.sourceforge.net/JSBSim.xsl"?>
<fdm_config name="stabilizer_rocket" version="2.0" release="BETA"    
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"    
    xsi:noNamespaceSchemaLocation="http://jsbsim.sourceforge.net/JSBSim.xsd">    

    <fileheader>        
        <author>Mateusz Pilecki / Auto-generated</author>        
        <filecreationdate>2026-06-15</filecreationdate>        
        <description>            
            150 kg sounding rocket with 4 canards (cross config).            
            Vertical ascent plus active stabilisation via PPO.            
            Thrust applied via external_reactions (no engine subsystem).        
        </description>    
    </fileheader>    

    <metrics>        
        <wingarea  unit="FT2">  0.1902 </wingarea>   <wingspan  unit="FT">   0.492  </wingspan>    <chord     unit="FT">   0.492  </chord>        <htailarea unit="FT2">  0.0    </htailarea>        
        <htailarm  unit="FT">   0.0    </htailarm>        
        <vtailarea unit="FT2">  0.0    </vtailarea>        
        <vtailarm  unit="FT">   0.0    </vtailarm>        

        <location name="AERORP" unit="IN">            
            <x> 32.5 </x>            
            <y>  0.0 </y>            
            <z>  0.0 </z>        
        </location>        

        <location name="EYEPOINT" unit="IN">            
            <x>  0.0 </x>            
            <y>  0.0 </y>            
            <z>  0.0 </z>        
        </location>        

        <location name="VRP" unit="IN">            
            <x> 30.0 </x>            
            <y>  0.0 </y>            
            <z>  0.0 </z>        
        </location>    
    </metrics>    
	<mass_balance>        
        <ixx unit="SLUG*FT2">  0.184  </ixx>        
        <iyy unit="SLUG*FT2">  2.950  </iyy>        
        <izz unit="SLUG*FT2">  2.950  </izz>        
        <ixy unit="SLUG*FT2">  0.0    </ixy>        
        <ixz unit="SLUG*FT2">  0.0    </ixz>        
        <iyz unit="SLUG*FT2">  0.0    </iyz>        
        
        <emptywt unit="LBS"> 110.23 </emptywt>   

        <location name="CG" unit="IN">            
            <x> 30.0 </x>            
            <y>  0.0 </y>            
            <z>  0.0 </z>        
        </location>    
    </mass_balance> 

    <ground_reactions>        
        <contact type="STRUCTURE" name="TAIL">            
            <location unit="IN">                
                <x> 59.1 </x>                
                <y>  0.0 </y>                
                <z>  0.0 </z>            
            </location>            
            <static_friction>  0.3 </static_friction>            
            <dynamic_friction> 0.3 </dynamic_friction>            
            <spring_coeff  unit="LBS/FT">     5000 </spring_coeff>            
            <damping_coeff unit="LBS/FT/SEC"> 500  </damping_coeff>            
            <retractable>0</retractable>        
        </contact>    
    </ground_reactions>    

    <external_reactions>        
        <force name="thrust" frame="BODY" unit="LBS">            
            <location unit="IN">                
                <x> 59.1 </x>                
                <y>  0.0 </y>                
                <z>  0.0 </z>            
            </location>            
            <direction>                
                <x> 1.0 </x>                
                <y> 0.0 </y>                
                <z> 0.0 </z>            
            </direction>        
        </force>    
    </external_reactions>    

    <flight_control name="FCS: stabilizer_rocket">        

        <channel name="Pitch">            
            <summer name="fcs/pitch-sum">                
                <input>fcs/elevator-cmd-norm</input>                
                <clipto>                    
                    <min>-1.0</min>                    
                    <max> 1.0</max>                
                </clipto>            
            </summer>            
            <pure_gain name="fcs/elevator-pos-rad">                
                <input>fcs/pitch-sum</input>                
                <gain>0.349</gain>  <output>fcs/elevator-pos-rad</output>            
            </pure_gain>        
        </channel>        

        <channel name="Yaw">            
            <summer name="fcs/yaw-sum">                
                <input>fcs/rudder-cmd-norm</input>                
                <clipto>                    
                    <min>-1.0</min>                    
                    <max> 1.0</max>                
                </clipto>            
            </summer>            
            <pure_gain name="fcs/rudder-pos-rad">                
                <input>fcs/yaw-sum</input>                
                <gain>0.5236</gain>  <output>fcs/rudder-pos-rad</output>            
            </pure_gain>        
        </channel>        

        <channel name="Roll">            
            <summer name="fcs/roll-sum">                
                <input>fcs/aileron-cmd-norm</input>                
                <clipto>                    
                    <min>-1.0</min>                    
                    <max> 1.0</max>                
                </clipto>            
            </summer>            
            <pure_gain name="fcs/left-aileron-pos-rad">                
                <input>fcs/roll-sum</input>                
                <gain>0.5236</gain>  <output>fcs/left-aileron-pos-rad</output>            
            </pure_gain>        
        </channel>    
    </flight_control>    

    <aerodynamics>        

        <axis name="DRAG">            
            <function name="aero/coefficient/CD0">                
                <description>Zero-lift (body) drag</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <value>0.30</value>                
                </product>            
            </function>            
            <function name="aero/coefficient/CDalpha">                
                <description>Drag due to alpha (induced drag)</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>aero/alpha-rad</property>                    
                    <property>aero/alpha-rad</property>                    
                    <value>1.5</value>                
                </product>            
            </function>            
            <function name="aero/coefficient/CDde">                
                <description>Drag due to pitch-canard deflection</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>fcs/elevator-pos-rad</property>                    
                    <property>fcs/elevator-pos-rad</property>                    
                    <value>0.5</value>                
                </product>            
            </function>        
        </axis>        

        <axis name="SIDE">            
            <function name="aero/coefficient/CYbeta">                
                <description>Side force due to sideslip</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>aero/beta-rad</property>                    
                    <value>-4.0</value>                
                </product>            
            </function>            
            <function name="aero/coefficient/CYdr">                
                <description>Side force due to yaw-canard deflection</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>fcs/rudder-pos-rad</property>                    
                    <value>1.5</value>                
                </product>            
            </function>        
        </axis>        

        <axis name="LIFT">            
            <function name="aero/coefficient/CLalpha">                
                <description>Lift (normal force) due to angle of attack</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>aero/alpha-rad</property>                    
                    <value>3.0</value>                
                </product>            
            </function>            
            <function name="aero/coefficient/CLde">                
                <description>Lift due to pitch-canard deflection</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>fcs/elevator-pos-rad</property>                    
                    <value>2.0</value>                
                </product>            
            </function>        
        </axis>        

        <axis name="ROLL">            
            <function name="aero/coefficient/Clp">                
                <description>Roll moment due to roll rate (damping)</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>metrics/bw-ft</property>                    
                    <property>aero/bi2vel</property>                    
                    <property>velocities/p-aero-rad_sec</property>                    
                    <value>-1.20</value>                
                </product>            
            </function>            
            <function name="aero/coefficient/Clda">                
                <description>Roll moment due to differential canard deflection</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>metrics/bw-ft</property>                    
                    <property>fcs/left-aileron-pos-rad</property>                    
                    <value>0.05</value>                
                </product>            
            </function>        
        </axis>        

        <axis name="PITCH">            
            <function name="aero/coefficient/Cmalpha">                
                <description>Pitch moment due to alpha (static stability)</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>metrics/cbarw-ft</property>                    
                    <property>aero/alpha-rad</property>                    
                    <value>-1.0</value>                
                </product>            
            </function>            
            <function name="aero/coefficient/Cmq">                
                <description>Pitch moment due to pitch rate (damping)</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>metrics/cbarw-ft</property>                    
                    <property>aero/ci2vel</property>                    
                    <property>velocities/q-aero-rad_sec</property>                    
                    <value>-12.0</value>                
                </product>            
            </function>            
            <function name="aero/coefficient/Cmde">                
                <description>Pitch moment due to pitch-canard deflection</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>metrics/cbarw-ft</property>                    
                    <property>fcs/elevator-pos-rad</property>                    
                    <value>3.5</value>  </product>            
            </function>        
        </axis>        

        <axis name="YAW">            
            <function name="aero/coefficient/Cnbeta">                
                <description>Yaw moment due to sideslip (static stability)</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>metrics/bw-ft</property>                    
                    <property>aero/beta-rad</property>                    
                    <value>2.5</value>   </product>            
            </function>            
            <function name="aero/coefficient/Cnr">                
                <description>Yaw moment due to yaw rate (damping)</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>metrics/bw-ft</property>                    
                    <property>aero/bi2vel</property>                    
                    <property>velocities/r-aero-rad_sec</property>                    
                    <value>-12.0</value>                
                </product>            
            </function>            
            <function name="aero/coefficient/Cndr">                
                <description>Yaw moment due to yaw-canard deflection</description>                
                <product>                    
                    <property>aero/qbar-psf</property>                    
                    <property>metrics/Sw-sqft</property>                    
                    <property>metrics/bw-ft</property>                    
                    <property>fcs/rudder-pos-rad</property>                    
                    <value>3.5</value>  </product>            
            </function>        
        </axis>    
    </aerodynamics>
</fdm_config>
